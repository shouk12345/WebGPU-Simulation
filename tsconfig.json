{
  "compilerOptions": {
    "allowImportingTsExtensions": true,
    "target": "ESNext",
    "module": "ESNext",
    "moduleResolution": "bundler", 
    "strict": true,               
    "esModuleInterop": true,
    "skipLibCheck": true,
    "forceConsistentCasingInFileNames": true,
    "isolatedModules": true,
    "noEmit": true,               
    "types": ["@webgpu/types"]    
  },
  "include": [
    "core/**/*", 
    "demo/**/*", 
    "end.d.ts"
  ]              
}